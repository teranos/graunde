{
    "name": "ground",
    "description": "Workflow enforcement for Claude Code",
    "targetType": "executable",
    "targetName": "ground",
    "sourcePaths": ["source"],
    "stringImportPaths": ["."],
    "dflags": ["-betterC"],
    "libs": ["sqlite3"],
    "lflags": ["-L/usr/local/opt/sqlite/lib"],
    "extraDependencyFiles": [".ctfe/sand"],
    "preBuildCommands": ["git describe --tags --always > .version || true", "date -u +%Y-%m-%dT%H:%M:%SZ > .builddate", "tools/wind"]
}
