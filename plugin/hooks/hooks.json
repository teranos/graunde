{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v graunde >/dev/null && exec graunde"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v graunde >/dev/null && exec graunde"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v graunde >/dev/null && exec graunde"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v graunde >/dev/null && exec graunde || echo '{\"systemMessage\": \"The graunde plugin is installed but not yet functional. Help the user get it working — figure out what is needed and ask questions if anything is unclear.\"}'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v graunde >/dev/null && exec graunde"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v graunde >/dev/null && exec graunde"
          }
        ]
      }
    ]
  }
}
